#!/usr/bin/env python3
"""AutoAim 流媒体服务器

启动 MediaMTX 和 HTTP 服务器，提供视频播放页面和录制控制 API。
"""

import json
import os
import signal
import subprocess
import sys
import threading
from functools import partial
from http.server import SimpleHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path

# ── 配置常量 ──────────────────────────────────────────────────────────────────

defaultInstallRoot = Path("/opt/autoaim")
defaultPlayerPort = 18080
defaultMediamtxPort = 8889
playerRoute = "/res/playing.html"
playerFile = "playing.html"
fifoRecorderStart = "/tmp/autoaim/recorder/start"
fifoRecorderStop = "/tmp/autoaim/recorder/stop"
contextRecorderPath = "/tmp/autoaim/recorder/context"
fifoPlayerPause = "/tmp/autoaim/player/pause"
fifoPlayerStep = "/tmp/autoaim/player/step"
contextPlayerPath = "/tmp/autoaim/player/context"


# ── HTTP Handler ─────────────────────────────────────────────────────────────


class AutoAimHandler(SimpleHTTPRequestHandler):
    """处理 HTTP 请求，提供静态文件服务和录制控制 API。"""

    rootDirectory: str = str(defaultInstallRoot)

    def do_GET(self) -> None:
        if self.path in ("/autoaim", "/autoaim/"):
            self.path = playerRoute
        elif self.path == "/api/context":
            self.handleContext()
            return
        return super().do_GET()

    def do_POST(self) -> None:
        if self.path == "/api/record":
            self.handleRecord()
            return
        if self.path == "/api/play_pause":
            try:
                paused = self.readPlayerPaused()
            except OSError as e:
                self.jsonResponse(503, {"status": "error", "message": str(e)})
                return
            self.write_to_fifo(fifoPlayerPause, "false" if paused else "true")
            return
        if self.path == "/api/step_forward":
            self.write_to_fifo(fifoPlayerStep, "1")
            return
        if self.path == "/api/step_backward":
            self.write_to_fifo(fifoPlayerStep, "-1")
            return
        self.send_error(404, "Not Found")

    def handleRecord(self) -> None:
        contentLength = int(self.headers.get("Content-Length", 0))
        body = self.rfile.read(contentLength).decode().strip()

        if body in ("1", "true"):
            self.write_to_fifo(fifoRecorderStart, "1")
        elif body in ("0", "false"):
            self.write_to_fifo(fifoRecorderStop, "1")
        else:
            self.jsonResponse(
                400, {"status": "error", "message": "invalid value"})

    def write_to_fifo(self, path: str, value: str) -> None:
        fd = None
        try:
            fd = os.open(path, os.O_WRONLY | os.O_NONBLOCK)
            os.write(fd, value.encode())
            self.jsonResponse(200, {"status": "ok"})
        except OSError as e:
            self.jsonResponse(500, {"status": "error", "message": str(e)})
        finally:
            if fd is not None:
                os.close(fd)

    def handleContext(self) -> None:
        try:
            recordContext = self.readContext()
        except OSError as e:
            self.jsonResponse(503, {"status": "error", "message": str(e)})
            return
        self.jsonResponse(200, {"status": "ok", "context": recordContext})

    def readContext(self) -> dict[str, object]:
        context: dict[str, object] = {
            "filename": "not started",
            "recordStatus": "unavailable",
            "recordOn": False,
            "recorderAvailable": False,
            "playing": True,
            "playerAvailable": False,
        }

        parsed_recorder = False
        try:
            with open(contextRecorderPath, "r") as f:
                for line in f:
                    name, separator, content = line.partition(":")
                    if not separator:
                        continue
                    value = content.strip()
                    if name == "filename":
                        context["filename"] = value
                        parsed_recorder = True
                    elif name == "enabled":
                        context["recordOn"] = value in ("1", "true")
                        parsed_recorder = True
        except OSError:
            parsed_recorder = False

        if parsed_recorder:
            context["recorderAvailable"] = True
            if context["recordOn"]:
                context["recordStatus"] = "recording"
            elif context["filename"] not in ("", "not started"):
                context["recordStatus"] = "stopped"
            else:
                context["recordStatus"] = "ready"

        try:
            context["playing"] = not self.readPlayerPaused()
            context["playerAvailable"] = True
        except OSError:
            pass

        return context

    def readPlayerPaused(self) -> bool:
        parsed = False
        paused = False
        with open(contextPlayerPath, "r") as f:
            for line in f:
                name, separator, content = line.partition(":")
                if not separator:
                    continue
                if name != "paused":
                    continue
                paused = content.strip() in ("1", "true")
                parsed = True
        if not parsed:
            raise OSError(f"Empty player context: {contextPlayerPath}")
        return paused

    def jsonResponse(self, code: int, data: dict) -> None:
        body = json.dumps(data).encode()
        self.send_response(code)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, format: str, *args) -> None:
        sys.stderr.write(f"[HTTP] {format % args}\n")


# ── 进程管理 ──────────────────────────────────────────────────────────────────


class ProcessManager:
    """管理子进程的生命周期。"""

    def __init__(self) -> None:
        self.process: subprocess.Popen[str] | None = None

    def start(self, args: list[str], cwd: Path) -> subprocess.Popen[str]:
        self.process = subprocess.Popen(
            args, cwd=cwd, start_new_session=True,
        )
        return self.process

    def terminate(self) -> None:
        proc = self.process
        if proc is None or proc.poll() is not None:
            return
        os.killpg(proc.pid, signal.SIGTERM)
        try:
            proc.wait(timeout=5)
        except subprocess.TimeoutExpired:
            os.killpg(proc.pid, signal.SIGKILL)
            proc.wait(timeout=5)


# ── 服务器 ────────────────────────────────────────────────────────────────────


class StreamServer:
    """AutoAim 流媒体服务器，协调 MediaMTX 和 HTTP 服务。"""

    def __init__(
        self,
        installRoot: Path,
        playerPort: int,
        mediamtxPort: int,
    ) -> None:
        self.installRoot = installRoot
        self.playerPort = playerPort
        self.mediamtxPort = mediamtxPort
        self.binDir = installRoot / "bin"
        self.resDir = installRoot / "res"
        self.mediamtxProcess = ProcessManager()
        self.httpServer: ThreadingHTTPServer | None = None
        self.shutdownEvent = threading.Event()

    def run(self) -> int:
        self.validateFiles()
        self.startMediamtx()
        self.startHttpServer()
        self.setupSignalHandlers()

        host = os.environ.get("HOSTNAME", "<ip>")
        self.printStartupInfo(host)

        try:
            self.httpServer.serve_forever()
        finally:
            self.cleanup()

        return 0

    def validateFiles(self) -> None:
        required = [
            self.binDir / "mediamtx",
            self.resDir / "mediamtx.yml",
            self.resDir / playerFile,
        ]
        for path in required:
            if not path.is_file():
                raise SystemExit(f"Missing file: {path}")

    def startMediamtx(self) -> None:
        args = [
            str(self.binDir / "mediamtx"),
            str(self.resDir / "mediamtx.yml"),
        ]
        self.mediamtxProcess.start(args, self.installRoot)
        threading.Thread(target=self.watchMediamtx, daemon=True).start()

    def watchMediamtx(self) -> None:
        proc = self.mediamtxProcess.process
        if proc is None:
            return
        exitCode = proc.wait()
        if exitCode != 0:
            print(f"MediaMTX exited with code {exitCode}", file=sys.stderr)
        self.shutdown()

    def startHttpServer(self) -> None:
        AutoAimHandler.rootDirectory = str(self.installRoot)
        self.httpServer = ThreadingHTTPServer(
            ("0.0.0.0", self.playerPort),
            partial(AutoAimHandler, directory=str(self.installRoot)),
        )

    def setupSignalHandlers(self) -> None:
        signal.signal(signal.SIGINT, lambda *_: self.shutdown())
        signal.signal(signal.SIGTERM, lambda *_: self.shutdown())

    def shutdown(self) -> None:
        if self.shutdownEvent.is_set():
            return
        self.shutdownEvent.set()
        if self.httpServer:
            threading.Thread(target=self.httpServer.shutdown,
                             daemon=True).start()

    def cleanup(self) -> None:
        if self.httpServer:
            self.httpServer.server_close()
        self.mediamtxProcess.terminate()

    def printStartupInfo(self, host: str) -> None:
        print("AutoAim stream server started.\n")
        print(f"Please access -> http://<ip>:{self.playerPort}/autoaim\n")
        print("Press Ctrl+C to stop.")


# ── 入口 ──────────────────────────────────────────────────────────────────────


def main() -> int:
    installRoot = Path(sys.argv[1]) if len(
        sys.argv) > 1 else defaultInstallRoot
    playerPort = int(os.environ.get(
        "AUTOAIM_PLAYER_PORT", str(defaultPlayerPort)))
    mediamtxPort = int(os.environ.get(
        "AUTOAIM_MEDIAMTX_PORT", str(defaultMediamtxPort)))

    server = StreamServer(installRoot, playerPort, mediamtxPort)
    return server.run()


if __name__ == "__main__":
    raise SystemExit(main())
